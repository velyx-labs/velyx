{
  "name": "velyx",
  "version": "2.1.3",
  "description": "CLI to add composable UI components to Laravel projects",
  "author": "",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "velyx": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "laravel",
    "cli",
    "ui",
    "blade",
    "tailwind",
    "alpine"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/velyx-labs/velyx.git"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "scripts": {
    "build:dev": "cross-env NODE_ENV=development VELYX_REGISTRY_URL=http://velyx.test/api/v1 tsup",
    "build": "cross-env NODE_ENV=production VELYX_REGISTRY_URL=https://registry.velyx.dev/api/v1 tsup",
    "check:ci": "pnpm run lint && pnpm run typecheck",
    "clean": "rimraf dist",
    "dev": "cross-env NODE_ENV=development VELYX_REGISTRY_URL=http://velyx.test/api/v1 tsup --watch",
    "check": "pnpm run format:write && eslint --fix",
    "format:check": "prettier --check \"**/*.{ts,tsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,mdx}\" --cache",
    "lint": "eslint",
    "prepublishOnly": "pnpm run build",
    "pub:beta": "pnpm build && pnpm publish --no-git-checks --access public --tag beta",
    "pub:next": "pnpm build && pnpm publish --no-git-checks --access public --tag next",
    "pub:release": "pnpm build && pnpm publish --access public",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "start": "node dist/index.js",
    "start:dev": "cross-env NODE_ENV=development VELYX_REGISTRY_URL=http://velyx.test/api/v1 node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.5",
    "kleur": "^4.1.5",
    "ora": "^9.4.0",
    "prompts": "^2.4.2",
    "vite-tsconfig-paths": "^6.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.39.4",
    "@eslint/json": "^0.14.0",
    "@eslint/markdown": "^7.5.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.1",
    "@types/prompts": "^2.4.9",
    "@vitest/coverage-v8": "^4.1.7",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "prettier": "3.8.0",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.17",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  }
}
